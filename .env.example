# Copia a .env y completa los valores.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

VITE_USE_LOCAL_DATA=false

# Google Gemini (opcional)
# VITE_AI_ENABLED: false (o vacío) desactiva toda la IA en la UI y en red.
# true + VITE_GEMINI_API_KEY activa pulido, descripciones sugeridas, etc.
VITE_AI_ENABLED=false
# Solo el modal «Convertir a votación» en Propuestas (pregunta + opciones sugeridas), aunque VITE_AI_ENABLED=false
VITE_AI_PROPOSAL_CONVERT_POLL=false
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
